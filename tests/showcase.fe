// ═══════════════════════════════════════════════════════════
//  Ferrite v2.0 — Complete Feature Showcase
// ═══════════════════════════════════════════════════════════

// ── Top-level Constants ─────────────────────────────────────
constant PI: float = 3.14159;
constant MAX_EPOCHS: int = 100;
constant MODEL_NAME: string = "FerriteMLP";
constant DEBUG: bool = false;

// ── Enums (Algebraic Data Types) ────────────────────────────
enum Color {
    Red;
    Green;
    Blue;
}

enum Option<T> {
    Some(T);
    None;
}

// ── Groups (Structs) with Methods ───────────────────────────
group Vector2 {
    x: float;
    y: float;

    fun magnitude(self) -> float {
        return self.x;
    }

    fun scale(self, factor: float) -> float {
        return self.x;
    }
}

group Layer {
    units: int;
    activation: string;
}

// ── Generic Functions with Trait Bounds ──────────────────────
fun identity<T>(x: T) -> T {
    return x;
}

fun constrained<T: Add + Mul>(a: T, b: T) -> T {
    return a;
}

fun with_shape<N: shape>(dim: int) -> int
    where N > 0 {
    return dim;
}

// ── Effect-Annotated Functions (ML Contexts) ────────────────
infer fun predict(input: int) -> int {
    return input * 2;
}

train fun optimize(loss: float) -> float {
    return loss * 0.99;
}

// ── Tensor Types with Shape Validation ──────────────────────
fun zeros() -> int {
    return 0;
}

fun build_model() {
    param weights: Tensor<float, (784, 128)> = zeros();
    param bias: Tensor<float, (128)> = zeros();
    param kernel: Tensor<float, (3, 3, 64)> = zeros();
    param embeddings: Tensor<float, (B, 768)> = zeros();
}

// ── Full Expression Coverage ────────────────────────────────
fun expressions_demo() {
    // Arithmetic
    keep a: int = 10;
    keep b: int = 20;
    keep sum: int = a + b;
    keep diff: int = a - b;
    keep prod: int = a * b;
    keep quot: int = a / b;
    keep rem: int = a % b;

    // Unary
    keep neg: int = -a;
    keep flag: bool = true;
    keep flipped: bool = !flag;

    // Comparison
    keep lt: bool = a < b;
    keep gt: bool = a > b;
    keep le: bool = a <= b;
    keep ge: bool = a >= b;
    keep eq: bool = a == b;
    keep ne: bool = a != b;

    // Logical
    keep both: bool = flag && !flag;
    keep either: bool = flag || !flag;

    // Float arithmetic
    keep radius: float = 5.0;
    keep area: float = PI * radius * radius;
}

// ── Control Flow ────────────────────────────────────────────
fun classify(score: int) -> string {
    if score > 90 {
        return "excellent";
    } elif score > 70 {
        return "good";
    } elif score > 50 {
        return "average";
    } else {
        return "needs improvement";
    }
}

fun countdown(n: int) -> int {
    keep i: int = n;
    while i > 0 {
        if i == 42 {
            stop;
        }
        i = i - 1;
    }
    return i;
}

fun loop_control() {
    keep i: int = 0;
    while i < 100 {
        i = i + 1;
        if i % 2 == 0 {
            skip;
        }
    }
}

// ── Pattern Matching ────────────────────────────────────────
fun describe(code: int) -> string {
    match code {
        case 200 => {
            return "OK";
        }
        case 404 => {
            return "Not Found";
        }
        case 500 => {
            return "Server Error";
        }
        default => {
            return "Unknown";
        }
    }
}

// ── ML Blocks (Infer / Train) ───────────────────────────────
fun training_loop() {
    train {
        keep lr: float = 0.001;
        keep momentum: float = 0.9;
        keep loss: float = 42.0;
    }

    infer {
        keep prediction: int = predict(10);
    }
}

// ── Group Literals & Field Access ───────────────────────────
fun create_objects() {
    keep origin: Vector2 = Vector2 { x: 0.0, y: 0.0 };
    keep point: Vector2 = Vector2 { x: 3.0, y: 4.0 };

    keep fc1: Layer = Layer { units: 128, activation: "relu" };
    keep fc2: Layer = Layer { units: 10, activation: "softmax" };

    keep mag: float = point.magnitude();
    keep scaled: float = point.scale(2.5);
}

// ── Scoping Rules ───────────────────────────────────────────
fun scoping_demo() {
    keep x: int = 1;
    if true {
        keep x: int = 2;         // Shadowing across scopes — allowed
        keep inner: int = x + 1; // inner = 3
    }
    // x is still 1 here, inner is not accessible
    keep result: int = x;
}

// ── Entry Point ─────────────────────────────────────────────
fun main() -> int {
    keep score: int = 85;
    keep grade: string = classify(score);
    keep status: string = describe(200);
    keep count: int = countdown(10);

    expressions_demo();
    loop_control();
    training_loop();
    create_objects();
    scoping_demo();
    build_model();

    return 0;
}
